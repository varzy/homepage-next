{
  "name": "homepage-next",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "exam": "npm run fetch-posts && npm run format && npm run lint",
    "build": "next build",
    "build:debug": "next build  --debug",
    "start": "next start",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "oxfmt",
    "fetch-posts": "tsx scripts/fetch-posts.ts",
    "fetch-posts:force": "tsx scripts/fetch-posts.ts --force",
    "release-posts": "git pull && npm run exam && git add . && git commit -m 'Release: Update posts.' && git push"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.4",
    "@notionhq/client": "^5.20.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "notion-to-md": "^3.1.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "rss": "^1.2.2",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/rss": "^0.0.32",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "postcss": "^8.5.12",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "raw-loader": "^4.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.13.1"
}
